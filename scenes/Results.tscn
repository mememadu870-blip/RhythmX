[gd_scene load_steps=3 format=3 uid="uid://results_scene"]

[ext_resource type="Script" path="res://scripts/ui/ResultsUI.gd" id="1_results"]
[ext_resource type="Theme" path="res://resources/theme/MainTheme.tres" id="2_theme"]

[node name="Results" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_results")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.02, 0.02, 0.05, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 20

[node name="SpacerTop" type="Control" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 50)
layout_mode = 2

[node name="GradeContainer" type="CenterContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="GradeLabel" type="Label" parent="VBoxContainer/GradeContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.85, 0, 1)
theme_override_font_sizes/font_size = 120
text = "S"

[node name="NewRecordBadge" type="Label" parent="VBoxContainer/GradeContainer"]
visible = false
layout_mode = 2
offset_left = 80
offset_top = 60
offset_right = 180
offset_bottom = 90
theme_override_colors/font_color = Color(1, 0.5, 0, 1)
theme_override_font_sizes/font_size = 20
text = "NEW RECORD!"

[node name="ScoreContainer" type="VBoxContainer" parent="VBoxContainer"]
layout_mode = 2
alignment = 1

[node name="ScoreValue" type="Label" parent="VBoxContainer/ScoreContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 48
text = "985,420"
horizontal_alignment = 1

[node name="ScoreLabel" type="Label" parent="VBoxContainer/ScoreContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.6, 0.7, 1)
text = "SCORE"
horizontal_alignment = 1

[node name="StatsContainer" type="GridContainer" parent="VBoxContainer"]
layout_mode = 2
size_flags_horizontal = 4
columns = 2

[node name="MaxComboLabel" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
text = "Max Combo:"

[node name="MaxComboValue" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
text = "256"

[node name="PerfectLabel" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 1, 1, 1)
text = "Perfect:"

[node name="PerfectValue" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 1, 1, 1)
text = "180"

[node name="GreatLabel" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.9, 0.3, 1)
text = "Great:"

[node name="GreatValue" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.9, 0.3, 1)
text = "30"

[node name="GoodLabel" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.8, 0.5, 1)
text = "Good:"

[node name="GoodValue" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.8, 0.5, 1)
text = "10"

[node name="MissLabel" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.3, 0.3, 1)
text = "Miss:"

[node name="MissValue" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.3, 0.3, 1)
text = "5"

[node name="AccuracyLabel" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
text = "Accuracy:"

[node name="AccuracyValue" type="Label" parent="VBoxContainer/StatsContainer"]
layout_mode = 2
text = "98.50%"

[node name="BadgesContainer" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
alignment = 1

[node name="FullComboBadge" type="Label" parent="VBoxContainer/BadgesContainer"]
visible = false
layout_mode = 2
theme_override_colors/font_color = Color(0.4, 1, 1, 1)
theme_override_font_sizes/font_size = 20
text = "FULL COMBO!"

[node name="AllPerfectBadge" type="Label" parent="VBoxContainer/BadgesContainer"]
visible = false
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.85, 0, 1)
theme_override_font_sizes/font_size = 20
text = "ALL PERFECT!"

[node name="SpacerBottom" type="Control" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 30)
layout_mode = 2

[node name="ButtonContainer" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
alignment = 1

[node name="RetryButton" type="Button" parent="VBoxContainer/ButtonContainer"]
custom_minimum_size = Vector2(120, 50)
layout_mode = 2
text = "Retry"

[node name="NextButton" type="Button" parent="VBoxContainer/ButtonContainer"]
custom_minimum_size = Vector2(120, 50)
layout_mode = 2
text = "Next"

[node name="BackButton" type="Button" parent="VBoxContainer/ButtonContainer"]
custom_minimum_size = Vector2(120, 50)
layout_mode = 2
text = "Back"

[node name="SongInfo" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = -60
grow_horizontal = 2
grow_vertical = 0
alignment = 1

[node name="SongName" type="Label" parent="SongInfo"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.6, 0.7, 1)
text = "Neon Pulsar"

[node name="Separator" type="Label" parent="SongInfo"]
layout_mode = 2
text = " - "

[node name="Artist" type="Label" parent="SongInfo"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.6, 0.7, 1)
text = "Synthwave Masters"

[connection signal="pressed" from="VBoxContainer/ButtonContainer/RetryButton" to="." method="on_retry_pressed"]
[connection signal="pressed" from="VBoxContainer/ButtonContainer/BackButton" to="." method="on_back_pressed"]