[gd_scene load_steps=3 format=3 uid="uid://settings_scene"]

[ext_resource type="Script" path="res://scripts/ui/SettingsUI.gd" id="1_settings"]
[ext_resource type="Theme" path="res://resources/theme/MainTheme.tres" id="2_theme"]

[node name="Settings" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_settings")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.05, 0.1, 1)

[node name="Header" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 60
grow_horizontal = 2

[node name="BackButton" type="Button" parent="Header"]
custom_minimum_size = Vector2(60, 60)
layout_mode = 2
text = "←"

[node name="TitleLabel" type="Label" parent="Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 28
text = "Settings"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="Header"]
custom_minimum_size = Vector2(60, 0)
layout_mode = 2

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = 70
grow_horizontal = 2
grow_vertical = 2

[node name="SettingsVBox" type="VBoxContainer" parent="ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3

[node name="AudioSection" type="VBoxContainer" parent="ScrollContainer/SettingsVBox"]
layout_mode = 2

[node name="SectionTitle" type="Label" parent="ScrollContainer/SettingsVBox/AudioSection"]
